/// Formatting module: Formatter for building formatted output.
/// Bootstrap limitation: write operations are no-ops until pointer
/// write and memory allocation support is added to codegen.

/// Formatter is a buffer for building formatted output.
pub struct Formatter {
    buf: String,
}

impl Formatter {
    /// Create a new empty formatter.
    pub fn new() -> Formatter {
        return Formatter { buf: String.new() };
    }

    /// Write a string to the formatter.
    /// Bootstrap: no-op (requires string concat via pointer write).
    pub fn write_str(mutref self, s: ref String) -> Result {
        return Ok(());
    }

    /// Write a single character.
    /// Bootstrap: no-op (requires buffer append via pointer write).
    pub fn write_char(mutref self, c: Char) -> Result {
        return Ok(());
    }

    /// Return the accumulated string.
    pub fn finish(owned self) -> String {
        return self.buf;
    }
}
