/// Bool type and methods.
/// Bool is a built-in primitive. This module provides trait implementations.

import core.fmt.Formatter;
import core.result.Result;

impl Equatable : Bool {
    fn eq(ref self, other: ref Self) -> Bool { return self == other; }
    fn ne(ref self, other: ref Self) -> Bool { return self != other; }
}

impl Printable : Bool {
    fn fmt(ref self, f: mutref Formatter) -> Result {
        return Ok(());
    }
}
